# --- Telegram Bot Settings ---
# Main bot token (fallback: TOKEN)
BOT_TOKEN='YOUR_TELEGRAM_BOT_TOKEN'
# Destination chat/channel ID for outgoing messages (fallback: CHANNEL_NAME)
CHAT_ID='YOUR_MAIN_CHANNEL_ID'
# Optional technical channel ID (fallback: TECH_CHANNEL_NAME)
TECH_CHAT_ID='YOUR_TECH_CHANNEL_ID'
# Optional averaging channel ID (fallback: AV_CHANNEL_NAME)
AV_CHAT_ID='YOUR_AV_CHANNEL_ID'

# --- Google Sheets Settings ---
# Google Service Account JSON key file name
GS_JS_FILE='service_account.json'
# Google Sheet URL where the bot stores trade data
GS_SHEET_FILE='YOUR_GOOGLE_SHEET_URL'
# Google Sheet tab number (0-indexed)
G_LIST='0'

# --- Logging Settings ---
# Set to True to log 'Pong received from Bybit Stream' messages (for debugging)
# Set to False (or omit) to disable logging of Pong messages (default)
LOG_PONG_MESSAGES=False

# --- Queue and Webhook Settings ---
REDIS_URL='redis://localhost:6379/0'
TELEGRAM_QUEUE_NAME='telegram_queue'

WEBHOOK_HOST='https://YOUR_DOMAIN_OR_NGROK'
WEBHOOK_PATH='/webhook'
WEBHOOK_PORT='8000'

# --- Exchange Settings ---
# Default exchange for price tracking ('bybit' or 'bingx')
EXCHANGE='bingx'

# --- BingX API Settings ---
# API Key for BingX (if needed for advanced features)
BINGX_API_KEY='YOUR_BINGX_API_KEY'
# API Secret for BingX (if needed for advanced features)
BINGX_API_SECRET='YOUR_BINGX_API_SECRET'
